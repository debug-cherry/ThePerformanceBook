---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The Performance Book - Squeezing every drop of efficiency out of software." } = Astro.props;

// Ensure base URL pathing is correct
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
    <title>{title} | The Performance Book</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts: Outfit (Headings) and Inter (Body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />

    <!-- KaTeX CSS for Math Rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css" integrity="sha384-G5Z2UCGj7j1BgvR6fI2Y/8G0N356WbUfK+r5l02yWpHu1B2r9s7z39W9H31k1M" crossorigin="anonymous" />
  </head>
  <body class="bg-[#0b0f19] text-[#e2e8f0] font-sans antialiased selection:bg-violet-500/30 selection:text-violet-200 min-h-screen flex flex-col">
    <!-- Premium Header -->
    <header class="border-b border-slate-800/80 bg-[#0c101d]/60 backdrop-blur-md sticky top-0 z-40 transition-colors duration-300">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={`${baseUrl}/`} class="group flex items-center gap-2.5 font-display font-bold text-xl tracking-tight text-white">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-violet-600 to-indigo-500 flex items-center justify-center shadow-lg shadow-violet-500/20 group-hover:scale-105 transition-transform duration-200">
            <span class="text-white text-base font-extrabold font-display">P</span>
          </div>
          <span class="bg-gradient-to-r from-slate-100 via-slate-100 to-slate-300 bg-clip-text text-transparent group-hover:text-violet-300 transition-colors duration-200">
            The Performance Book
          </span>
        </a>
        
        <nav class="flex items-center gap-6">
          <a href={`${baseUrl}/`} class="text-sm font-medium text-slate-300 hover:text-white transition-colors duration-200">
            Articles
          </a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-400 hover:text-white transition-colors duration-200 flex items-center gap-1">
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content Container with max reading length limit -->
    <main class="flex-grow max-w-[65ch] w-full mx-auto px-6 py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-900 bg-[#080b12] py-8 text-center text-slate-500 text-xs">
      <div class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <p>© {new Date().getFullYear()} The Performance Book. All rights reserved.</p>
        <p class="flex gap-4">
          <a href={`${baseUrl}/`} class="hover:text-slate-300 transition-colors">Home</a>
          <span class="text-slate-700">•</span>
          <a href="https://github.com" class="hover:text-slate-300 transition-colors">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Base Typography Overrides for Premium Aesthetic */
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
    color: #ffffff;
    font-weight: 700;
    letter-spacing: -0.025em;
  }
  
  body {
    font-family: 'Inter', sans-serif;
  }

  code, pre {
    font-family: 'Fira Code', monospace;
  }

  /* Styling KaTeX formula blocks for clean dark mode presentation */
  .katex-display {
    padding: 1.25rem;
    background-color: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(51, 65, 85, 0.3);
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
  }

  .katex {
    font-size: 1.05em;
    color: #cbd5e1;
  }

  /* Shiki Code Block Styles */
  pre {
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(51, 65, 85, 0.25);
    margin: 1.5rem 0;
    font-size: 0.9em;
    line-height: 1.6;
    overflow-x: auto;
    background-color: #0d1117 !important;
  }

  /* Article prose styles to simulate tailwind typography */
  .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    color: #cbd5e1;
  }

  .prose h2 {
    font-size: 1.65rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(51, 65, 85, 0.2);
    padding-bottom: 0.4rem;
  }

  .prose h3 {
    font-size: 1.35rem;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
  }

  .prose li {
    margin-bottom: 0.5rem;
    line-height: 1.625;
  }

  .prose a {
    color: #a78bfa;
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .prose a:hover {
    color: #c084fc;
  }

  .prose blockquote {
    border-left: 4px solid #8b5cf6;
    padding-left: 1.25rem;
    font-style: italic;
    color: #94a3b8;
    margin: 1.5rem 0;
  }
</style>
