---
---
<button
  id="theme-toggle"
  class="relative p-2 rounded-xl bg-slate-900/60 dark:bg-slate-800/40 border border-slate-800/60 dark:border-slate-700/40 hover:bg-slate-800/80 dark:hover:bg-slate-700/60 text-slate-400 hover:text-white transition-all duration-200 cursor-pointer shadow-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 flex items-center justify-center"
  aria-label="Toggle Theme"
>
  <!-- Sun Icon (visible in Dark Mode) -->
  <svg
    id="theme-toggle-sun"
    class="w-5 h-5 hidden dark:block transition-transform duration-300 hover:rotate-45"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  
  <!-- Moon Icon (visible in Light Mode) -->
  <svg
    id="theme-toggle-moon"
    class="w-5 h-5 block dark:hidden transition-transform duration-300 hover:-rotate-12"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  };

  const setupToggle = () => {
    const toggle = document.getElementById("theme-toggle");
    if (toggle) {
      // Remove any existing listener before attaching a new one
      toggle.removeEventListener("click", handleToggleClick);
      toggle.addEventListener("click", handleToggleClick);
    }
  };

  // Setup on initial load
  setupToggle();

  // Support Astro View Transitions
  document.addEventListener("astro:after-swap", setupToggle);
</script>
