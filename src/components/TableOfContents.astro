---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter out top-level h1 or deep headings, focusing on h2 and h3
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// If no headings are present, do not render the TOC button/panel
if (tocHeadings.length === 0) {
  return null;
}
---

<!-- Floating Trigger Button (Mobile/Tablet Only) -->
<button
  id="toc-trigger"
  class="fixed bottom-6 right-6 z-50 p-3.5 rounded-full bg-bg-surface hover:bg-bg-surface/90 text-text-base shadow-lg border border-border-muted flex items-center justify-center hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-bg-surface focus:ring-offset-2 focus:ring-offset-bg-base lg:hidden"
  aria-label="Open Table of Contents"
  aria-expanded="false"
  aria-controls="toc-drawer"
>
  <!-- List Icon (lucide-like custom SVG) -->
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5.5 h-5.5">
    <line x1="4" x2="20" y1="9" y2="9"></line>
    <line x1="4" x2="20" y1="15" y2="15"></line>
    <circle cx="2" cy="9" r="1"></circle>
    <circle cx="2" cy="15" r="1"></circle>
  </svg>
</button>

<!-- Backdrop Overlay (Mobile/Tablet Only) -->
<div
  id="toc-backdrop"
  class="fixed inset-0 bg-bg-base/70 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
></div>

<!-- Drawer Sidebar -->
<aside
  id="toc-drawer"
  class="fixed top-0 right-0 h-full w-full max-w-[340px] bg-bg-base border-l border-border-muted z-50 translate-x-full transition-transform duration-300 ease-out shadow-2xl flex flex-col lg:static lg:h-auto lg:w-full lg:max-w-none lg:bg-transparent lg:border-l-0 lg:z-auto lg:translate-x-0 lg:shadow-none"
  aria-hidden="true"
>
  <!-- Drawer Header (Mobile/Tablet Only) -->
  <div class="h-16 px-6 border-b border-border-muted flex items-center justify-between lg:hidden">
    <h3 class="text-base font-semibold text-text-base tracking-tight">Table of Contents</h3>
    <button
      id="toc-close"
      class="p-2 rounded-lg text-text-muted hover:text-text-base hover:bg-bg-surface/20 transition-colors focus:outline-none"
      aria-label="Close Table of Contents"
    >
      <!-- X Icon -->
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Drawer Body (Links) -->
  <nav class="flex-grow overflow-y-auto px-6 py-6 lg:px-0 lg:py-0 scrollbar-thin">
    <ul class="space-y-2">
      {tocHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class={`toc-link block text-[13px] transition-all duration-150 py-1.5 border-l-2 border-transparent pl-3 ${
              heading.depth === 2
                ? "font-medium text-text-muted hover:text-text-base"
                : "text-text-muted/70 hover:text-text-base ml-3 pl-2.5 border-l border-border-muted/30"
            }`}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<script>
  let activeObserver: IntersectionObserver | null = null;

  function initTOC() {
    const trigger = document.getElementById('toc-trigger');
    const closeBtn = document.getElementById('toc-close');
    const backdrop = document.getElementById('toc-backdrop');
    const drawer = document.getElementById('toc-drawer');
    const links = document.querySelectorAll('.toc-link');

    if (trigger && closeBtn && backdrop && drawer) {
      const elTrigger = trigger;
      const elCloseBtn = closeBtn;
      const elBackdrop = backdrop;
      const elDrawer = drawer;

      let isOpen = false;

      function openDrawer() {
        isOpen = true;
        elTrigger.setAttribute('aria-expanded', 'true');
        elDrawer.setAttribute('aria-hidden', 'false');
        elBackdrop.setAttribute('aria-hidden', 'false');
        elDrawer.classList.remove('translate-x-full');
        elDrawer.classList.add('translate-x-0');
        elBackdrop.classList.remove('opacity-0', 'pointer-events-none');
        elBackdrop.classList.add('opacity-100', 'pointer-events-auto');
        document.body.classList.add('overflow-hidden');
      }

      function closeDrawer() {
        isOpen = false;
        elTrigger.setAttribute('aria-expanded', 'false');
        elDrawer.setAttribute('aria-hidden', 'true');
        elBackdrop.setAttribute('aria-hidden', 'true');
        elDrawer.classList.remove('translate-x-0');
        elDrawer.classList.add('translate-x-full');
        elBackdrop.classList.remove('opacity-100', 'pointer-events-auto');
        elBackdrop.classList.add('opacity-0', 'pointer-events-none');
        document.body.classList.remove('overflow-hidden');
      }

      elTrigger.removeEventListener('click', openDrawer);
      elTrigger.addEventListener('click', () => {
        if (isOpen) closeDrawer();
        else openDrawer();
      });

      elCloseBtn.removeEventListener('click', closeDrawer);
      elCloseBtn.addEventListener('click', closeDrawer);
      elBackdrop.removeEventListener('click', closeDrawer);
      elBackdrop.addEventListener('click', closeDrawer);

      const keyHandler = (e: KeyboardEvent) => {
        if (e.key === 'Escape' && isOpen) closeDrawer();
      };
      document.removeEventListener('keydown', keyHandler);
      document.addEventListener('keydown', keyHandler);

      links.forEach(link => {
        link.removeEventListener('click', closeDrawer);
        link.addEventListener('click', () => {
          setTimeout(closeDrawer, 150);
        });
      });
    }

    // Scroll-Spy Setup
    if (activeObserver) {
      activeObserver.disconnect();
      activeObserver = null;
    }

    const headings = Array.from(document.querySelectorAll('article h2, article h3'));
    const tocLinks = document.querySelectorAll('.toc-link');

    if (headings.length === 0 || tocLinks.length === 0) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -70% 0px',
      threshold: 0
    };

    activeObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          if (!id) return;
          
          tocLinks.forEach((link) => {
            const href = link.getAttribute('href')?.substring(1);
            if (href === id) {
              link.classList.add('active-heading');
              link.setAttribute('aria-current', 'location');
            } else {
              link.classList.remove('active-heading');
              link.removeAttribute('aria-current');
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach((heading) => {
      if (heading.getAttribute('id')) {
        activeObserver?.observe(heading);
      }
    });
  }

  // Setup on page loads and view transition swaps
  initTOC();
  document.addEventListener('astro:page-load', initTOC);
</script>

<style>
  /* Custom scrollbar for TOC menu */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: var(--color-border-muted);
    border-radius: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }

  /* Active Highlight Styling */
  .toc-link.active-heading {
    color: var(--color-text-base) !important;
    font-weight: 600;
    border-left-color: var(--color-border-muted) !important;
  }
</style>
