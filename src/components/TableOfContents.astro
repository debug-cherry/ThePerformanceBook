---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter out top-level h1 or deep headings, focusing on h2 and h3
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// If no headings are present, do not render the TOC button/panel
if (tocHeadings.length === 0) {
  return null;
}
---

<!-- Floating Trigger Button -->
<button
  id="toc-trigger"
  class="fixed bottom-6 right-6 z-50 p-3.5 rounded-full bg-violet-600 hover:bg-violet-500 text-white shadow-lg shadow-violet-500/20 border border-violet-400/20 flex items-center justify-center hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 focus:ring-offset-[#0b0f19]"
  aria-label="Open Table of Contents"
  aria-expanded="false"
  aria-controls="toc-drawer"
>
  <!-- List Icon (lucide-like custom SVG) -->
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5.5 h-5.5">
    <line x1="4" x2="20" y1="9" y2="9"></line>
    <line x1="4" x2="20" y1="15" y2="15"></line>
    <circle cx="2" cy="9" r="1"></circle>
    <circle cx="2" cy="15" r="1"></circle>
  </svg>
</button>

<!-- Backdrop Overlay -->
<div
  id="toc-backdrop"
  class="fixed inset-0 bg-[#060810]/70 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Drawer Sidebar -->
<aside
  id="toc-drawer"
  class="fixed top-0 right-0 h-full w-full max-w-[340px] bg-[#0c101d] border-l border-slate-800/80 z-50 translate-x-full transition-transform duration-300 ease-out shadow-2xl flex flex-col"
  aria-hidden="true"
>
  <!-- Drawer Header -->
  <div class="h-16 px-6 border-b border-slate-800/60 flex items-center justify-between">
    <h3 class="text-base font-semibold text-white tracking-tight">Table of Contents</h3>
    <button
      id="toc-close"
      class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800/50 transition-colors focus:outline-none"
      aria-label="Close Table of Contents"
    >
      <!-- X Icon -->
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Drawer Body (Links) -->
  <nav class="flex-grow overflow-y-auto px-6 py-6 scrollbar-thin">
    <ul class="space-y-3.5">
      {tocHeadings.map((heading) => (
        <li class={heading.depth === 3 ? "pl-4 border-l border-slate-800/40" : ""}>
          <a
            href={`#${heading.slug}`}
            class={`toc-link block text-sm transition-all duration-150 py-1 hover:translate-x-1 ${
              heading.depth === 2
                ? "font-medium text-slate-200 hover:text-violet-300"
                : "text-slate-400 hover:text-violet-300 text-[13px]"
            }`}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<script>
  function initTOC() {
    const trigger = document.getElementById('toc-trigger');
    const closeBtn = document.getElementById('toc-close');
    const backdrop = document.getElementById('toc-backdrop');
    const drawer = document.getElementById('toc-drawer');
    const links = document.querySelectorAll('.toc-link');

    if (!trigger || !closeBtn || !backdrop || !drawer) return;

    let isOpen = false;

    function openDrawer() {
      isOpen = true;
      trigger.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      backdrop.setAttribute('aria-hidden', 'false');

      // Add classes for styling/transitions
      drawer.classList.remove('translate-x-full');
      drawer.classList.add('translate-x-0');
      
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100', 'pointer-events-auto');

      // Prevent body scroll
      document.body.classList.add('overflow-hidden');
    }

    function closeDrawer() {
      isOpen = false;
      trigger.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      backdrop.setAttribute('aria-hidden', 'true');

      // Remove classes for styling/transitions
      drawer.classList.remove('translate-x-0');
      drawer.classList.add('translate-x-full');

      backdrop.classList.remove('opacity-100', 'pointer-events-auto');
      backdrop.classList.add('opacity-0', 'pointer-events-none');

      // Re-enable body scroll
      document.body.classList.remove('overflow-hidden');
    }

    // Toggle on trigger click
    trigger.addEventListener('click', () => {
      if (isOpen) {
        closeDrawer();
      } else {
        openDrawer();
      }
    });

    // Close on closeBtn or backdrop click
    closeBtn.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeDrawer();
      }
    });

    // Close on link click (smooth scrolling anchor jump)
    links.forEach(link => {
      link.addEventListener('click', () => {
        // Delay slightly for smooth transitions
        setTimeout(closeDrawer, 200);
      });
    });
  }

  // Support Astro View Transitions and standard page loads
  document.addEventListener('astro:page-load', initTOC);
  // Fallback for direct page loads/non-transition pages
  initTOC();
</script>

<style>
  /* Custom scrollbar for TOC menu */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: #1e293b;
    border-radius: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: #334155;
  }
</style>
