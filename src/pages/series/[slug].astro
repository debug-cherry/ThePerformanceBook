---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const seriesEntries = await getCollection('series');
  return seriesEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, description } = entry.data;

// Get all non-draft posts linked to this specific series
const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.series?.id === entry.id)
  // Default sort: Ascending chronological (Old to New)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

// Helper function to strip markdown and extract a plain text preview
function getPlainPreview(body: string, length = 180) {
  const cleanText = body
    .replace(/[#*`_\[\]()\-+]/g, '') // Strips markdown tokens
    .replace(/\s+/g, ' ')            // Collapses white spaces
    .trim();
  return cleanText.length > length ? cleanText.substring(0, length) + '...' : cleanText;
}

// Get the base path
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={title} description={description}>
  <section class="py-6 mb-8 border-b border-border-muted flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div class="max-w-2xl">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded text-[10px] font-bold text-text-base tracking-wider uppercase mb-3">
        Series Curation
      </span>
      <h1 class="text-3xl font-extrabold tracking-tight text-text-base leading-tight mb-2">
        {title}
      </h1>
      <p class="text-text-muted text-base leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Sort Selector Tool -->
    <div class="inline-flex items-center self-end gap-2.5 rounded-xl border border-border-muted bg-bg-surface/35 px-4 py-2 shadow-sm">
      <label for="series-sort-select" class="text-xs font-semibold text-text-muted select-none">
        Sort:
      </label>
      <select 
        id="series-sort-select" 
        class="bg-transparent text-xs font-bold text-text-base focus:outline-none border-none cursor-pointer pr-1"
      >
        <option value="old-to-new" class="bg-bg-base text-text-base">Oldest First</option>
        <option value="new-to-old" class="bg-bg-base text-text-base">Newest First</option>
        <option value="a-to-z" class="bg-bg-base text-text-base">Title: A-Z</option>
        <option value="z-to-a" class="bg-bg-base text-text-base">Title: Z-A</option>
      </select>
    </div>
  </section>

  <!-- Cards Layout Container -->
  <div id="sort-cards-wrapper" class="cards-grid">
    {posts.map(post => {
      return (
        <article 
          class="post-card group"
          data-date={post.data.date.toISOString()} 
          data-title={post.data.title}
        >
          <!-- Left Column: Flex-Grow container to fill card width -->
          <div class="card-body-content">
            <div class="card-meta">
              {post.data.series_order && (
                <span class="part-badge">Part {post.data.series_order}</span>
              )}
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            
            <h2>
              <a href={`${baseUrl}/posts/${post.id}/`} class="card-link">{post.data.title}</a>
            </h2>
            
            <p class="card-description">{post.data.description}</p>
            <p class="card-preview">{getPlainPreview(post.body || '')}</p>
          </div>

          <!-- Right Column: Flex-Locked Link -->
          <div class="card-action-wrapper">
            <a href={`${baseUrl}/posts/${post.id}/`} class="read-more-btn">
              <span>Read Article</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>

<style>
  .cards-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  /* Flexbox Layout Config */
  .post-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem; /* Generous spacer gutter between text and link */
    padding: 2rem;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border-muted);
    border-radius: 8px;
    width: 100%;
    transition: border-color 0.3s ease;
  }

  .post-card:hover {
    border-color: var(--color-text-muted);
  }

  /* Text Wrapper: Fills all empty space */
  .card-body-content {
    flex: 1;
    min-width: 0; /* Prevents flex wrapping overflow breaks */
  }

  /* Link Wrapper: Remains static and locked */
  .card-action-wrapper {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Typography Width Reset */
  .card-body-content h2,
  .card-body-content p {
    width: 100%;
    max-width: 100%; /* Ensures text expands across the wide container */
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .part-badge {
    background-color: var(--color-bg-base);
    color: var(--color-text-base);
    padding: 0.15rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--color-border-muted);
  }

  .read-more-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .read-more-btn:hover {
    color: var(--color-text-muted);
  }

  .read-more-btn:hover .arrow {
    transform: translateX(3px);
  }

  .arrow {
    display: inline-block;
    transition: transform 0.15s ease;
  }

  .card-link {
    color: var(--color-text-base);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  
  .card-link:hover {
    color: var(--color-text-muted);
  }
  
  .card-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }
  
  .card-preview {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.85;
    font-style: italic;
    background-color: rgba(255, 255, 255, 0.02);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--color-border-muted);
    font-family: monospace;
    line-height: 1.6;
    transition: border-color 0.3s ease;
  }

  .card-preview:hover {
    border-color: var(--color-text-muted);
  }
  
  .card-body-content h2 {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
  }

  /* Responsive Adjustments */
  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .card-action-wrapper {
      align-self: flex-end;
    }
  }
</style>

<script>
  function initSorter() {
    const select = document.getElementById('series-sort-select') as HTMLSelectElement | null;
    const wrapper = document.getElementById('sort-cards-wrapper');
    if (!select || !wrapper) return;

    select.addEventListener('change', () => {
      const cards = Array.from(wrapper.querySelectorAll('.post-card'));
      const sortValue = select.value;

      cards.sort((a, b) => {
        const titleA = a.getAttribute('data-title') || '';
        const titleB = b.getAttribute('data-title') || '';
        const dateA = new Date(a.getAttribute('data-date') || 0).getTime();
        const dateB = new Date(b.getAttribute('data-date') || 0).getTime();

        if (sortValue === 'old-to-new') {
          return dateA - dateB;
        } else if (sortValue === 'new-to-old') {
          return dateB - dateA;
        } else if (sortValue === 'a-to-z') {
          return titleA.localeCompare(titleB);
        } else if (sortValue === 'z-to-a') {
          return titleB.localeCompare(titleA);
        }
        return 0;
      });

      // Re-append cards in sorted order
      cards.forEach(card => wrapper.appendChild(card));
    });
  }

  // Run on page loads
  document.addEventListener('astro:page-load', initSorter);
  initSorter();
</script>
