---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

// Formatted Date
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Series Logic
const isSeries = !!post.data.series;
let seriesPosts: CollectionEntry<'blog'>[] = [];
let currentIndex = -1;
let prevPost = null;
let nextPost = null;

if (isSeries) {
  seriesPosts = allPosts
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.series_order || 0) - (b.data.series_order || 0));

  currentIndex = seriesPosts.findIndex((p) => p.id === post.id);
  prevPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
  nextPost = currentIndex < seriesPosts.length - 1 ? seriesPosts[currentIndex + 1] : null;
}

// Get the base path
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={post.data.title} description={post.data.description} coverImage={post.data.coverImage} date={post.data.date}>
  <!-- Floating Table of Contents Component -->
  <TableOfContents headings={headings} />

  <!-- Navigation / Back to Home -->
  <a
    href={`${baseUrl}/`}
    class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-400 hover:text-white group transition-colors duration-200 mb-8"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="group-hover:-translate-x-1 transition-transform duration-200"
    >
      <path d="m12 19-7-7 7-7"></path>
      <path d="M19 12H5"></path>
    </svg>
    Back to Articles
  </a>

  <!-- Header metadata -->
  <article class="prose">
    <header class="mb-10">
      {post.data.coverImage && (
        <div class="mb-8 rounded-2xl overflow-hidden border border-slate-800/80 aspect-video sm:aspect-[21/9] relative shadow-lg shadow-black/20">
          <img
            src={post.data.coverImage.startsWith('http') ? post.data.coverImage : `${baseUrl}${post.data.coverImage}`}
            alt={post.data.coverAlt || post.data.title}
            class="w-full h-full object-cover"
          />
        </div>
      )}
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-violet-950/40 text-violet-300 border border-violet-800/40 shadow-sm shadow-violet-950/10">
            Article
          </span>
          <time datetime={post.data.date.toISOString()} class="text-xs text-slate-400 font-medium">
            {formattedDate}
          </time>
        </div>
        
        <!-- Bookmark Toggle Button -->
        <button
          id="bookmark-toggle"
          data-post-id={post.id}
          data-post-title={post.data.title}
          data-post-description={post.data.description}
          data-post-date={post.data.date.toISOString()}
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 hover:bg-slate-200 dark:bg-slate-900/60 dark:hover:bg-slate-800/60 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white border border-slate-200 dark:border-slate-800/60 transition-all duration-200 cursor-pointer shadow-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50"
          aria-label="Bookmark Article"
        >
          <svg
            id="bookmark-icon-empty"
            class="w-3.5 h-3.5 block"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
          </svg>
          <svg
            id="bookmark-icon-filled"
            class="w-3.5 h-3.5 hidden text-violet-500 fill-violet-500"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
          </svg>
          <span id="bookmark-text">Bookmark</span>
        </button>
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white leading-tight">
        {post.data.title}
      </h1>

      <p class="text-slate-400 text-lg leading-relaxed mt-4 italic font-normal">
        {post.data.description}
      </p>
    </header>

    <!-- Series Panel -->
    {isSeries && (
      <div class="bg-gradient-to-b from-slate-900/60 to-slate-900/20 border border-violet-500/10 rounded-2xl p-6 mb-10 shadow-lg shadow-black/10">
        <h3 class="text-sm font-bold text-violet-300 tracking-wider uppercase mb-3.5 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-violet-400"></span>
          Series: {post.data.series}
        </h3>
        <p class="text-xs text-slate-400 mb-4">
          This article is part of a {seriesPosts.length}-part series. Follow along below:
        </p>
        <ol class="space-y-2.5">
          {seriesPosts.map((p, idx) => (
            <li class="flex items-center gap-2 text-sm">
              <span class={`flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold ${
                p.id === post.id
                  ? 'bg-violet-600 text-white shadow-md shadow-violet-500/25'
                  : 'bg-slate-800/50 text-slate-400 border border-slate-700/50'
              }`}>
                {idx + 1}
              </span>
              {p.id === post.id ? (
                <span class="font-semibold text-white">
                  {p.data.title} <span class="text-xs font-normal text-violet-400 ml-1.5">(You are here)</span>
                </span>
              ) : (
                <a
                  href={`${baseUrl}/posts/${p.id}/`}
                  class="text-slate-400 hover:text-violet-300 transition-colors font-medium hover:underline decoration-violet-500/30 underline-offset-4"
                >
                  {p.data.title}
                </a>
              )}
            </li>
          ))}
        </ol>
      </div>
    )}

    <!-- Dynamic Markdown Content -->
    <div class="mt-8">
      <Content />
    </div>

    <!-- Series Navigation Pagination -->
    {isSeries && (prevPost || nextPost) && (
      <nav class="flex flex-col sm:flex-row gap-4 justify-between border-t border-slate-800/60 pt-8 mt-12">
        {prevPost ? (
          <a
            href={`${baseUrl}/posts/${prevPost.id}/`}
            class="flex-1 p-4 rounded-xl border border-slate-800/60 bg-[#0c101d]/40 hover:bg-[#0c101d]/80 hover:border-violet-500/20 group transition-all duration-200 text-left flex items-start gap-3.5"
          >
            <div class="mt-1 bg-slate-800 group-hover:bg-violet-950/60 p-2 rounded-lg text-slate-400 group-hover:text-violet-300 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m15 18-6-6 6-6"></path>
              </svg>
            </div>
            <div>
              <span class="block text-[11px] font-bold text-violet-400 tracking-wider uppercase mb-1">Previous Part</span>
              <span class="block text-sm font-semibold text-slate-200 group-hover:text-white transition-colors line-clamp-1">{prevPost.data.title}</span>
            </div>
          </a>
        ) : (
          <div class="flex-1 hidden sm:block"></div>
        )}

        {nextPost ? (
          <a
            href={`${baseUrl}/posts/${nextPost.id}/`}
            class="flex-1 p-4 rounded-xl border border-slate-800/60 bg-[#0c101d]/40 hover:bg-[#0c101d]/80 hover:border-violet-500/20 group transition-all duration-200 text-right flex flex-row-reverse items-start gap-3.5"
          >
            <div class="mt-1 bg-slate-800 group-hover:bg-violet-950/60 p-2 rounded-lg text-slate-400 group-hover:text-violet-300 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"></path>
              </svg>
            </div>
            <div>
              <span class="block text-[11px] font-bold text-violet-400 tracking-wider uppercase mb-1">Next Part</span>
              <span class="block text-sm font-semibold text-slate-200 group-hover:text-white transition-colors line-clamp-1">{nextPost.data.title}</span>
            </div>
          </a>
        ) : (
          <div class="flex-1 hidden sm:block"></div>
        )}
      </nav>
    )}
  </article>
</BaseLayout>

<script>
  interface Bookmark {
    id: string;
    title: string;
    description: string;
    date: string;
  }

  const getBookmarks = (): Bookmark[] => {
    try {
      return JSON.parse(localStorage.getItem('bookmarks') || '[]');
    } catch {
      return [];
    }
  };

  const saveBookmarks = (bookmarks: Bookmark[]) => {
    localStorage.setItem('bookmarks', JSON.stringify(bookmarks));
  };

  const setupBookmark = () => {
    const btn = document.getElementById('bookmark-toggle');
    if (!btn) return;

    const postId = btn.getAttribute('data-post-id') || '';
    const title = btn.getAttribute('data-post-title') || '';
    const description = btn.getAttribute('data-post-description') || '';
    const date = btn.getAttribute('data-post-date') || '';

    const iconEmpty = document.getElementById('bookmark-icon-empty');
    const iconFilled = document.getElementById('bookmark-icon-filled');
    const textSpan = document.getElementById('bookmark-text');

    const updateUI = (isBookmarked: boolean) => {
      if (isBookmarked) {
        iconEmpty?.classList.add('hidden');
        iconFilled?.classList.remove('hidden');
        if (textSpan) textSpan.textContent = 'Bookmarked';
      } else {
        iconEmpty?.classList.remove('hidden');
        iconFilled?.classList.add('hidden');
        if (textSpan) textSpan.textContent = 'Bookmark';
      }
    };

    // Check initial state
    let bookmarks = getBookmarks();
    let isBookmarked = bookmarks.some(b => b.id === postId);
    updateUI(isBookmarked);

    // Toggle logic
    const handleToggle = () => {
      bookmarks = getBookmarks();
      isBookmarked = bookmarks.some(b => b.id === postId);

      if (isBookmarked) {
        bookmarks = bookmarks.filter(b => b.id !== postId);
      } else {
        bookmarks.push({ id: postId, title, description, date });
      }

      saveBookmarks(bookmarks);
      updateUI(!isBookmarked);
    };

    btn.removeEventListener('click', handleToggle);
    btn.addEventListener('click', handleToggle);
  };

  // Run on initial load
  setupBookmark();

  // Support Astro View Transitions
  document.addEventListener('astro:after-swap', setupBookmark);
</script>
