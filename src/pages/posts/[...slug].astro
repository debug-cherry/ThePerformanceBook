---
import { getCollection, getEntry, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

// Formatted Date
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Series Logic
const isSeries = !!post.data.series;
let seriesEntry: CollectionEntry<'series'> | null = null;
let seriesPosts: CollectionEntry<'blog'>[] = [];
let currentIndex = -1;
let prevPost = null;
let nextPost = null;

if (isSeries && post.data.series) {
  const currentSeries = post.data.series;
  seriesEntry = await getEntry(currentSeries);
  seriesPosts = allPosts
    .filter((p) => p.data.series?.id === currentSeries.id)
    .sort((a, b) => (a.data.series_order || 0) - (b.data.series_order || 0));

  currentIndex = seriesPosts.findIndex((p) => p.id === post.id);
  prevPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
  nextPost = currentIndex < seriesPosts.length - 1 ? seriesPosts[currentIndex + 1] : null;
}

// Get the base path
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Map front matter values to technical width limits
const widthMapping = {
  narrow: '65ch',
  standard: '80ch',
  wide: '98ch',
  full: '128ch',
};
const selectedWidth = widthMapping[post.data.width || 'standard'];
---

<BaseLayout title={post.data.title} description={post.data.description} coverImage={post.data.coverImage} date={post.data.date} isPost={true}>
  <div class="viewport-wrapper" style={`--reading-width: ${selectedWidth};`}>
    
    <!-- Left Side Collapsible Panel (TOC) -->
    <aside class="left-hover-panel" aria-label="Table of Contents Sidebar">
      <div class="panel-inner-container">
        
        <!-- Collapsed Strip/Indicator (Always visible) -->
        <div class="collapse-strip">
          <span class="expand-arrow">→</span>
        </div>
        
        <!-- Table of Contents Content (Revealed on hover) -->
        <div class="toc-content-wrapper">
          <h4 class="sidebar-heading">ON THIS PAGE</h4>
          <TableOfContents headings={headings} />
        </div>
        
      </div>
    </aside>

    <!-- Centered Reading Pane -->
    <main class="centered-reading-pane">
      <!-- Navigation / Back to Home -->
      <a
        href={`${baseUrl}/`}
        class="inline-flex items-center gap-1.5 text-sm font-medium text-text-muted hover:text-text-base group transition-colors duration-200 mb-8"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:-translate-x-1 transition-transform duration-200"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Back to Articles
      </a>

      <!-- Header metadata -->
      <article class="prose max-w-none">
        <header class="mb-5">
          {post.data.coverImage && (
            <div class="mb-8 rounded-2xl overflow-hidden border border-border-muted aspect-video sm:aspect-[21/9] relative shadow-lg shadow-black/20">
              <img
                src={post.data.coverImage.startsWith('http') ? post.data.coverImage : `${baseUrl}${post.data.coverImage}`}
                alt={post.data.coverAlt || post.data.title}
                class="w-full h-full object-cover"
              />
            </div>
          )}
          <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-bg-surface/20 text-text-base border border-border-muted shadow-sm">
                Article
              </span>
              <time datetime={post.data.date.toISOString()} class="text-xs text-text-muted font-medium">
                {formattedDate}
              </time>
            </div>
            
            <div class="flex flex-wrap items-center gap-3">
              <!-- Bookmark Toggle Button -->
              <button
                id="bookmark-toggle"
                data-post-id={post.id}
                data-post-title={post.data.title}
                data-post-description={post.data.description}
                data-post-date={post.data.date.toISOString()}
                class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-bg-surface/10 hover:bg-bg-surface/20 text-text-muted hover:text-text-base border border-border-muted transition-all duration-200 cursor-pointer shadow-sm focus:outline-none focus:ring-2 focus:ring-bg-surface/50 h-8"
                aria-label="Bookmark Article"
              >
                <svg
                  id="bookmark-icon-empty"
                  class="w-3.5 h-3.5 block"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
                </svg>
                <svg
                  id="bookmark-icon-filled"
                  class="w-3.5 h-3.5 hidden text-text-base fill-text-base"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
                </svg>
                <span id="bookmark-text">Bookmark</span>
              </button>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-text-base leading-tight">
            {post.data.title}
          </h1>

          <p class="text-text-muted text-lg leading-relaxed mt-4 italic font-normal">
            {post.data.description}
          </p>
        </header>

        <!-- Utility Cards Group (Series, Github, Suggested Resources) -->
        <div class="post-utility-cards">
          <!-- 1. Part of Series Card (Existing) -->
          {seriesEntry && (
            <a href={`${baseUrl}/series/${seriesEntry.id}/`} class="utility-card">
              <div class="card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                  <polyline points="2 17 12 22 22 17"></polyline>
                  <polyline points="2 12 12 17 22 12"></polyline>
                </svg>
              </div>
              <div class="card-text">
                <span class="card-label">Part of series</span>
                <span class="card-title">{seriesEntry.data.title}</span>
              </div>
            </a>
          )}

          <!-- 2. Related GitHub Repository Card (Optional) -->
          {post.data.githubRepo && (
            <a href={`https://github.com/${post.data.githubRepo}`} target="_blank" rel="noopener noreferrer" class="utility-card">
              <div class="card-icon">
                <!-- GitHub SVG Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                  <path d="M9 18c-4.51 2-5-2-7-2"></path>
                </svg>
              </div>
              <div class="card-text">
                <span class="card-label">Related repository</span>
                <span class="card-title">{post.data.githubRepo}</span>
              </div>
            </a>
          )}

          <!-- 3. Suggested Resources Card (Optional & Collapsible) -->
          {post.data.suggestedResources && post.data.suggestedResources.length > 0 && (
            <details class="utility-card collapsible-card">
              <summary class="collapsible-summary">
                <div class="card-icon">
                  <!-- Book Open SVG Icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                  </svg>
                </div>
                <div class="card-text">
                  <span class="card-label">Suggested resources</span>
                  <span class="card-title">Explore papers, documentation, and reference links</span>
                </div>
                <div class="caret-wrapper">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="caret-svg">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </div>
              </summary>
              <div class="collapsible-content">
                <ul class="resources-list">
                  {post.data.suggestedResources.map((resource) => (
                    <li>
                      <a href={resource.url} target="_blank" rel="noopener noreferrer" class="resource-item-link">
                        <div class="resource-title-row">
                          <span class="resource-title">{resource.title}</span>
                          <span class="resource-domain-badge">{new URL(resource.url).hostname} →</span>
                        </div>
                        {resource.description && <p class="resource-description">{resource.description}</p>}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          )}
        </div>

        <!-- Dynamic Markdown Content -->
        <div class="mt-8">
          <Content />
        </div>

        <!-- Series Navigation Pagination -->
        {isSeries && (prevPost || nextPost) && (
          <nav class="flex flex-col sm:flex-row gap-4 justify-between border-t border-border-muted pt-8 mt-12">
            {prevPost ? (
              <a
                href={`${baseUrl}/posts/${prevPost.id}/`}
                class="flex-1 p-4 rounded-xl border border-border-muted bg-bg-surface/10 hover:bg-bg-surface/20 hover:border-bg-surface/50 group transition-all duration-200 text-left flex items-start gap-3.5"
              >
                <div class="mt-1 bg-bg-surface/20 group-hover:bg-bg-surface/40 p-2 rounded-lg text-text-muted group-hover:text-text-base transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m15 18-6-6 6-6"></path>
                  </svg>
                </div>
                <div>
                  <span class="block text-[11px] font-bold text-text-muted tracking-wider uppercase mb-1">Previous Part</span>
                  <span class="block text-sm font-semibold text-text-base group-hover:text-text-muted transition-colors line-clamp-1">{prevPost.data.title}</span>
                </div>
              </a>
            ) : (
              <div class="flex-1 hidden sm:block"></div>
            )}

            {nextPost ? (
              <a
                href={`${baseUrl}/posts/${nextPost.id}/`}
                class="flex-1 p-4 rounded-xl border border-border-muted bg-bg-surface/10 hover:bg-bg-surface/20 hover:border-bg-surface/50 group transition-all duration-200 text-right flex flex-row-reverse items-start gap-3.5"
              >
                <div class="mt-1 bg-bg-surface/20 group-hover:bg-bg-surface/40 p-2 rounded-lg text-text-muted group-hover:text-text-base transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m9 18 6-6-6-6"></path>
                  </svg>
                </div>
                <div>
                  <span class="block text-[11px] font-bold text-text-muted tracking-wider uppercase mb-1">Next Part</span>
                  <span class="block text-sm font-semibold text-text-base group-hover:text-text-muted transition-colors line-clamp-1">{nextPost.data.title}</span>
                </div>
              </a>
            ) : (
              <div class="flex-1 hidden sm:block"></div>
            )}
          </nav>
        )}
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .viewport-wrapper {
    position: relative;
    width: 100%;
    min-height: 100vh;
  }

  /* Centered Article Layout (Relative to the whole viewport) */
  .centered-reading-pane {
    max-width: var(--reading-width, 80ch);
    margin: 0 auto;
    padding: 4rem 1.5rem;
    width: 100%;
  }

  /* Fixed Left Sidebar */
  .left-hover-panel {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: 50px; /* Collapsed state width */
    background-color: var(--color-bg-base);
    border-right: 1px solid var(--color-border-muted);
    z-index: 50;
    overflow: hidden;
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Expand Sidebar on Hover */
  @media (min-width: 1024px) {
    .left-hover-panel:hover {
      width: 300px; /* Expanded state width */
      background-color: var(--color-bg-surface);
    }
  }

  /* Inner Wrapper must maintain fixed width to prevent text reflow */
  .panel-inner-container {
    display: flex;
    width: 300px;
    height: 100%;
  }

  /* Vertical Trigger Strip */
  .collapse-strip {
    width: 50px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .left-hover-panel:hover .collapse-strip {
    border-right-color: var(--color-border-muted);
  }

  .expand-arrow {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    transition: transform 0.3s ease;
  }

  .left-hover-panel:hover .expand-arrow {
    transform: rotate(180deg); /* Arrow flips inward when expanded */
  }

  /* TOC Links Container */
  .toc-content-wrapper {
    width: 250px;
    padding: 2rem 1.5rem;
    opacity: 0;
    transition: opacity 0.2s ease-in-out;
    overflow-y: auto;
  }

  .left-hover-panel:hover .toc-content-wrapper {
    opacity: 1;
  }

  .sidebar-heading {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  /* Mobile Treatment (Hide hover-panel, use standard inline top-page layout) */
  @media (max-width: 1023px) {
    .left-hover-panel,
    .panel-inner-container,
    .toc-content-wrapper {
      display: contents;
    }
    .collapse-strip,
    .sidebar-heading {
      display: none;
    }
  }

  /* Utility Cards Group */
  .post-utility-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    width: 100%;
  }

  /* Universal Card styling */
  .utility-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border-muted);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    width: 100%;
  }

  .utility-card:hover {
    border-color: var(--color-text-muted);
    background-color: rgba(27, 38, 59, 0.8);
  }

  .card-icon {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex-grow: 1;
    text-align: left;
  }

  .card-label {
    font-size: 0.725rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-title {
    font-size: 1rem;
    color: var(--color-text-base);
    font-weight: 700;
    line-height: 1.3;
  }

  /* Collapsible Native CSS configurations */
  .collapsible-card {
    display: block; /* Overrides default flex rules */
    padding: 0;
    cursor: pointer;
  }

  .collapsible-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    list-style: none; /* Removes default details arrow toggle indicator */
  }

  .collapsible-summary::-webkit-details-marker {
    display: none; /* Secondary Webkit target for default arrow dismissal */
  }

  .caret-wrapper {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .caret-svg {
    transition: transform 0.2s ease-in-out;
  }

  /* Rotate caret SVG on native tag open state change */
  details[open] .caret-svg {
    transform: rotate(180deg);
  }

  /* Expanded Inner Drawer Area */
  .collapsible-content {
    border-top: 1px solid var(--color-border-muted);
    padding: 1rem 1.25rem 1.25rem 1.25rem;
    cursor: default;
  }

  .resources-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .resource-item-link {
    display: block;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: background-color 0.15s ease;
  }

  .resource-item-link:hover {
    background-color: var(--color-bg-base);
  }

  .resource-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .resource-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  .resource-domain-badge {
    font-size: 0.775rem;
    color: var(--color-text-muted);
    opacity: 0.8;
  }

  .resource-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    line-height: 1.4;
    text-align: left;
  }
</style>

<script>
  interface Bookmark {
    id: string;
    title: string;
    description: string;
    date: string;
  }

  const getBookmarks = (): Bookmark[] => {
    try {
      return JSON.parse(localStorage.getItem('bookmarks') || '[]');
    } catch {
      return [];
    }
  };

  const saveBookmarks = (bookmarks: Bookmark[]) => {
    localStorage.setItem('bookmarks', JSON.stringify(bookmarks));
  };

  const setupBookmark = () => {
    const btn = document.getElementById('bookmark-toggle');
    if (!btn) return;

    const postId = btn.getAttribute('data-post-id') || '';
    const title = btn.getAttribute('data-post-title') || '';
    const description = btn.getAttribute('data-post-description') || '';
    const date = btn.getAttribute('data-post-date') || '';

    const iconEmpty = document.getElementById('bookmark-icon-empty');
    const iconFilled = document.getElementById('bookmark-icon-filled');
    const textSpan = document.getElementById('bookmark-text');

    const updateUI = (isBookmarked: boolean) => {
      if (isBookmarked) {
        iconEmpty?.classList.add('hidden');
        iconFilled?.classList.remove('hidden');
        if (textSpan) textSpan.textContent = 'Bookmarked';
      } else {
        iconEmpty?.classList.remove('hidden');
        iconFilled?.classList.add('hidden');
        if (textSpan) textSpan.textContent = 'Bookmark';
      }
    };

    // Check initial state
    let bookmarks = getBookmarks();
    let isBookmarked = bookmarks.some(b => b.id === postId);
    updateUI(isBookmarked);

    // Toggle logic
    const handleToggle = () => {
      bookmarks = getBookmarks();
      isBookmarked = bookmarks.some(b => b.id === postId);

      if (isBookmarked) {
        bookmarks = bookmarks.filter(b => b.id !== postId);
      } else {
        bookmarks.push({ id: postId, title, description, date });
      }

      saveBookmarks(bookmarks);
      updateUI(!isBookmarked);
    };

    btn.addEventListener('click', handleToggle);
  };

  // Setup on page loads and view transition swaps
  setupBookmark();
  document.addEventListener('astro:page-load', setupBookmark);
</script>
