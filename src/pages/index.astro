---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch all posts, filtering out drafts in production
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Fetch all series profile entries
const allSeries = await getCollection('series');
const seriesMap = new Map(allSeries.map((s) => [s.id, s]));

// Sort all posts by date (newest first)
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Filter standalone posts (no series associated)
const standalonePosts = sortedPosts.filter((p) => !p.data.series);

// Group series posts by series ID
const seriesGroups: Record<string, typeof allPosts> = {};
sortedPosts.forEach((post) => {
  if (post.data.series) {
    const seriesId = post.data.series.id;
    if (!seriesGroups[seriesId]) {
      seriesGroups[seriesId] = [];
    }
    seriesGroups[seriesId].push(post);
  }
});

// Sort each series chronologically by series_order
Object.keys(seriesGroups).forEach((seriesId) => {
  seriesGroups[seriesId].sort((a, b) => (a.data.series_order || 0) - (b.data.series_order || 0));
});

// Get the base path
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="py-6 mb-12 border-b border-border-muted">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-bg-surface to-bg-surface/90 border border-border-muted p-8 sm:p-10 shadow-2xl">
      <!-- Ambient background glow -->
      <div class="absolute -top-12 -left-12 w-48 h-48 bg-bg-base/20 rounded-full blur-3xl" aria-hidden="true"></div>
      <div class="absolute -bottom-12 -right-12 w-48 h-48 bg-bg-base/20 rounded-full blur-3xl" aria-hidden="true"></div>

      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-bg-base/20 text-text-base border border-border-muted tracking-wider uppercase mb-5">
        Systems & Software Engineering
      </span>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-text-base leading-tight mb-4">
        Unlocking High Performance
      </h1>
      <p class="text-text-base/80 text-base sm:text-lg max-w-xl leading-relaxed">
        Deep dives, architecture patterns, and optimizations from compiler intrinsics to high-concurrency engines.
      </p>
    </div>
  </section>

  <div class="space-y-12">
    <!-- Series Publications -->
    {Object.keys(seriesGroups).length > 0 && (
      <section>
        <h2 class="text-xl font-bold text-text-base tracking-tight mb-6 flex items-center gap-2.5">
          <span class="w-3.5 h-1.5 rounded-full bg-bg-surface"></span>
          Learning Series
        </h2>
        <div class="grid gap-6">
          {Object.entries(seriesGroups).map(([seriesId, posts]) => {
            const series = seriesMap.get(seriesId);
            const firstPostDate = new Date(posts[0].data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            });
            return (
              <div class="group relative overflow-hidden rounded-xl border border-border-muted bg-bg-surface/10 p-6 shadow-md hover:border-bg-surface/50 hover:bg-bg-surface/20 transition-all duration-300">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-bold text-text-muted tracking-wider uppercase flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-bg-surface"></span>
                    {posts.length} Parts
                  </span>
                  <span class="text-xs text-text-muted font-medium">Started {firstPostDate}</span>
                </div>
                <h3 class="text-lg font-bold text-text-base mb-2 group-hover:text-text-muted transition-colors">
                  <a href={`${baseUrl}/series/${seriesId}/`} class="hover:underline">
                    {series?.data.title || seriesId}
                  </a>
                </h3>
                <p class="text-sm text-text-muted mb-5 leading-relaxed">
                  {series?.data.description || "Explore theoretical models, mathematical formulas, and sample code step-by-step."}
                </p>
                <ol class="space-y-2.5 border-t border-border-muted pt-4">
                  {posts.map((p, idx) => (
                    <li class="flex items-start gap-2.5 text-sm">
                      <span class="flex items-center justify-center w-5 h-5 rounded-full bg-bg-surface/20 text-text-base text-[10px] font-bold border border-border-muted mt-0.5">
                        {idx + 1}
                      </span>
                      <a
                        href={`${baseUrl}/posts/${p.id}/`}
                        class="text-text-base hover:text-text-muted font-medium transition-colors hover:underline underline-offset-4 decoration-bg-surface/20"
                      >
                        {p.data.title}
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Standalone Posts -->
    <section>
      <h2 class="text-xl font-bold text-text-base tracking-tight mb-6 flex items-center gap-2.5">
        <span class="w-3.5 h-1.5 rounded-full bg-bg-surface"></span>
        Latest Articles
      </h2>
      <div class="space-y-6">
        {standalonePosts.map((post) => {
          const postDate = new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <article class="group relative overflow-hidden rounded-xl border border-border-muted bg-bg-surface/10 p-6 shadow-md hover:border-bg-surface/30 hover:bg-bg-surface/20 transition-all duration-300 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
              <div class="flex-grow">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-[10px] font-bold text-text-muted bg-bg-surface/20 px-2 py-0.5 rounded border border-border-muted">
                    Standalone
                  </span>
                  <time datetime={post.data.date.toISOString()} class="text-xs text-text-muted font-medium">
                    {postDate}
                  </time>
                </div>
                <h3 class="text-lg font-bold text-text-base mb-2 group-hover:text-text-muted transition-colors">
                  <a href={`${baseUrl}/posts/${post.id}/`}>
                    {post.data.title}
                  </a>
                </h3>
                <p class="text-sm text-text-muted leading-relaxed max-w-xl">
                  {post.data.description}
                </p>
              </div>
              <div class="flex items-center self-end sm:self-center">
                <a
                  href={`${baseUrl}/posts/${post.id}/`}
                  class="inline-flex items-center gap-1 text-xs font-semibold text-text-muted hover:text-text-base group-hover:translate-x-1.5 transition-all duration-200"
                  aria-label={`Read ${post.data.title}`}
                >
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>
