---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSeriesPartLabel } from '../utils/series';

// 1. Fetch collections, filtering out drafts in production
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const allSeries = await getCollection('series');
const seriesMap = new Map(allSeries.map((s) => [s.id, s]));

// 2. Sort posts globally by date descending (Absolute newest first)
const sortedPosts = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 3. Isolate the absolute latest post and its series context
const latestPost = sortedPosts[0];
const latestPostSeries = latestPost?.data.series ? await getEntry(latestPost.data.series) : null;

// 4. Filter standalone posts (no series associated)
const standalonePosts = sortedPosts.filter((p) => !p.data.series);

// 5. Group series posts by series ID
const seriesGroups: Record<string, typeof allPosts> = {};
allPosts.forEach((post) => {
  if (post.data.series) {
    const seriesId = post.data.series.id;
    (seriesGroups[seriesId] ??= []).push(post);
  }
});

// Sort each series chronologically by series_order
for (const seriesId in seriesGroups) {
  seriesGroups[seriesId].sort((a, b) => (a.data.series_order ?? 0) - (b.data.series_order ?? 0));
}

// 6. Base URL & Helper utilities
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const formatDate = (date: Date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title="Home">
  <div class="home-container">
    
    <!-- Latest Article Section -->
    <section class="latest-section">
      <h3 class="section-title">Latest Article</h3>
      
      {latestPost && (
        <article class="content-card latest-post-card group">
          <!-- Left Column: Flex-Grow container -->
          <div class="card-body-content">
            <div class="card-meta">
              
              <!-- Dynamic Badge Type Configuration -->
              {latestPostSeries ? (
                <span class="series-badge">
                  {getSeriesPartLabel(latestPost, seriesGroups[latestPost.data.series!.id])} • {latestPostSeries.data.title}
                </span>
              ) : (
                <span class="standalone-badge">
                  {latestPost.data.quickByte ? "Quick Byte" : "Standalone"}
                </span>
              )}
              
              <time datetime={latestPost.data.date.toISOString()}>
                {formatDate(latestPost.data.date)}
              </time>
            </div>
            
            <h2>
              <a href={`${baseUrl}/posts/${latestPost.id}/`} class="card-link">{latestPost.data.title}</a>
            </h2>
            
            <p class="card-description">{latestPost.data.description}</p>
          </div>

          <!-- Right Column: Flex-Locked Link -->
          <div class="card-action-wrapper">
            <a href={`${baseUrl}/posts/${latestPost.id}/`} class="read-more-btn">
              <span>Read Article</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </article>
      )}
    </section>

    <div class="space-y-12">
      <!-- Series Publications -->
      {Object.keys(seriesGroups).length > 0 && (
        <section>
          <h2 class="text-xl font-bold text-text-base tracking-tight mb-6 flex items-center gap-2.5">
            <span class="w-3.5 h-1.5 rounded-full bg-bg-surface"></span>
            Learning Series
          </h2>
          <div class="grid gap-6">
            {Object.entries(seriesGroups).map(([seriesId, posts]) => {
              const series = seriesMap.get(seriesId);
              return (
                <div class="content-card group">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-bold text-text-muted tracking-wider uppercase flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-bg-surface"></span>
                      {posts.length} Parts
                    </span>
                    <span class="text-xs text-text-muted font-medium">Started {formatDate(posts[0].data.date)}</span>
                  </div>
                  
                  <h3 class="text-lg font-bold text-text-base mb-2 group-hover:text-text-muted transition-colors">
                    <a href={`${baseUrl}/series/${seriesId}/`} class="hover:underline">
                      {series?.data.title || seriesId}
                    </a>
                  </h3>
                  
                  <p class="text-sm text-text-muted mb-5 leading-relaxed">
                    {series?.data.description || "Explore theoretical models, mathematical formulas, and sample code step-by-step."}
                  </p>
                  
                  <ol class="space-y-2.5 border-t border-border-muted pt-4">
                    {(() => {
                      let partIdx = 1;
                      return posts.map((p) => {
                        const isQB = p.data.quickByte;
                        const displayLabel = isQB ? "Q" : partIdx++;
                        return (
                          <li class="flex items-start gap-2.5 text-sm">
                            <span class:list={[
                              "flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold border border-border-muted mt-0.5",
                              isQB ? "bg-bg-base/40 text-text-muted" : "bg-bg-surface/20 text-text-base"
                            ]}>
                              {displayLabel}
                            </span>
                            <a
                              href={`${baseUrl}/posts/${p.id}/`}
                              class="text-text-base hover:text-text-muted font-medium transition-colors hover:underline underline-offset-4 decoration-bg-surface/20"
                            >
                              {p.data.title}
                            </a>
                          </li>
                        );
                      });
                    })()}
                  </ol>
                </div>
              );
            })}
          </div>
        </section>
      )}

      <!-- Standalone Posts -->
      {standalonePosts.length > 0 && (
        <section>
          <h2 class="text-xl font-bold text-text-base tracking-tight mb-6 flex items-center gap-2.5">
            <span class="w-3.5 h-1.5 rounded-full bg-bg-surface"></span>
            Standalone Articles
          </h2>
          <div class="space-y-6">
            {standalonePosts.map((post) => {
              return (
                <article class="content-card group flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                  <div class="flex-grow">
                    <div class="flex items-center gap-2 mb-2">
                      <time datetime={post.data.date.toISOString()} class="text-xs text-text-muted font-medium">
                        {formatDate(post.data.date)}
                      </time>
                    </div>
                    
                    <h3 class="text-lg font-bold text-text-base mb-2 group-hover:text-text-muted transition-colors">
                      <a href={`${baseUrl}/posts/${post.id}/`}>
                        {post.data.title}
                      </a>
                    </h3>
                    
                    <p class="text-sm text-text-muted leading-relaxed max-w-xl">
                      {post.data.description}
                    </p>
                  </div>
                  
                  <div class="flex items-center self-end sm:self-center">
                    <a
                      href={`${baseUrl}/posts/${post.id}/`}
                      class="inline-flex items-center gap-1 text-xs font-semibold text-text-muted hover:text-text-base group-hover:translate-x-1.5 transition-all duration-200"
                      aria-label={`Read ${post.data.title}`}
                    >
                      Read Article
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                      </svg>
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .home-container {
    max-width: 98ch;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .latest-section {
    margin-bottom: 4rem;
    width: 100%;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-base);
    margin-bottom: 1.5rem;
    padding-left: 0.5rem;
    border-left: 3px solid var(--color-border-muted);
  }

  /* Shared Card Styling base structure */
  .content-card {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--color-border-muted);
    background-color: rgba(27, 38, 59, 0.1); /* bg-bg-surface/10 equivalent */
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); /* shadow-md */
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .content-card:hover {
    border-color: rgba(65, 90, 119, 0.4);
    background-color: rgba(27, 38, 59, 0.2);
  }

  /* Latest Post Card Width Adjustments */
  .latest-post-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    width: 100%;
  }

  .card-body-content {
    flex: 1;
    min-width: 0;
  }

  .card-action-wrapper {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .card-body-content h2,
  .card-body-content p {
    width: 100%;
    max-width: 100%;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  /* Badges Styling */
  .standalone-badge,
  .series-badge {
    border: 1px solid var(--color-border-muted);
    padding: 0.15rem 0.5rem;
    font-size: 0.7rem;
    border-radius: 4px;
  }

  .standalone-badge {
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .series-badge {
    background-color: var(--color-bg-base);
    color: var(--color-text-base);
    font-weight: 700;
    max-width: 320px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .card-link {
    color: var(--color-text-base);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.25rem;
    transition: color 0.15s ease;
  }

  .card-link:hover {
    color: var(--color-text-muted);
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  .read-more-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .read-more-btn:hover {
    color: var(--color-text-muted);
  }

  .read-more-btn:hover .arrow {
    transform: translateX(3px);
  }

  .arrow {
    display: inline-block;
    transition: transform 0.15s ease;
  }

  /* Mobile responsiveness optimization */
  @media (max-width: 640px) {
    .latest-post-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .card-action-wrapper {
      align-self: flex-end;
    }
  }
</style>