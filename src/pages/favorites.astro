---
import BaseLayout from '../layouts/BaseLayout.astro';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Bookmarked Articles">
  <section class="py-6 mb-8 border-b border-slate-200 dark:border-slate-900">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight mb-2">
      Your Bookmarked Articles
    </h1>
    <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed">
      Articles you've saved to read later. Saved locally on your device.
    </p>
  </section>

  <!-- Container for bookmarks -->
  <div id="bookmarks-container" class="space-y-6">
    <!-- Loading/Empty State placeholder -->
    <div id="bookmarks-loading" class="text-center py-12 text-slate-500">
      Loading your bookmarks...
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ baseUrl }}>
  // Inline script runs client-side to render list
  function renderBookmarks() {
    const container = document.getElementById('bookmarks-container');
    if (!container) return;

    let bookmarks = [];
    try {
      bookmarks = JSON.parse(localStorage.getItem('bookmarks') || '[]');
    } catch (e) {
      bookmarks = [];
    }

    if (bookmarks.length === 0) {
      container.innerHTML = `
        <div class="text-center py-16 border border-dashed border-slate-200 dark:border-slate-800 rounded-2xl p-8">
          <svg class="w-12 h-12 text-slate-400 dark:text-slate-600 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z" />
          </svg>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">No bookmarked articles</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Explore the articles list and click "Bookmark" to save them here.</p>
          <a href="${baseUrl}/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold bg-violet-600 hover:bg-violet-700 text-white shadow-md hover:shadow-lg transition-all duration-200 cursor-pointer">
            Explore Articles
          </a>
        </div>
      `;
      return;
    }

    // Sort by date (newest first)
    bookmarks.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

    let html = '';
    bookmarks.forEach(post => {
      const postDate = new Date(post.date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });

      html += `
        <article class="group relative overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800/80 bg-slate-50/30 dark:bg-[#0c101d]/20 p-6 shadow-md hover:border-violet-500/20 hover:bg-slate-50 dark:hover:bg-[#0c101d]/50 transition-all duration-300 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
          <div class="flex-grow">
            <div class="flex items-center gap-2 mb-2">
              <time datetime="${post.date}" class="text-xs text-slate-500 font-medium">
                ${postDate}
              </time>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2 group-hover:text-violet-600 dark:group-hover:text-violet-300 transition-colors">
              <a href="${baseUrl}/posts/${post.id}/">
                ${post.title}
              </a>
            </h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl">
              ${post.description || ''}
            </p>
          </div>
          <div class="flex items-center justify-between sm:justify-end gap-6 self-stretch sm:self-center">
            <!-- Remove Bookmark button -->
            <button 
              onclick="removeBookmark('${post.id}')"
              class="text-xs font-semibold text-slate-400 hover:text-red-500 transition-colors duration-200 flex items-center gap-1 cursor-pointer"
              aria-label="Remove Bookmark"
            >
              Remove
            </button>
            <a
              href="${baseUrl}/posts/${post.id}/"
              class="inline-flex items-center gap-1 text-xs font-semibold text-violet-600 dark:text-violet-400 hover:text-violet-700 dark:hover:text-white group-hover:translate-x-1.5 transition-all duration-200"
            >
              Read
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </article>
      `;
    });

    container.innerHTML = html;
  }

  function removeBookmark(id) {
    let bookmarks = [];
    try {
      bookmarks = JSON.parse(localStorage.getItem('bookmarks') || '[]');
    } catch (e) {
      bookmarks = [];
    }
    bookmarks = bookmarks.filter(b => b.id !== id);
    localStorage.setItem('bookmarks', JSON.stringify(bookmarks));
    renderBookmarks();
  }

  // Bind globally so inline onclick works
  window.removeBookmark = removeBookmark;

  // Run on initial load
  renderBookmarks();

  // Support Astro View Transitions
  document.addEventListener('astro:after-swap', renderBookmarks);
</script>
